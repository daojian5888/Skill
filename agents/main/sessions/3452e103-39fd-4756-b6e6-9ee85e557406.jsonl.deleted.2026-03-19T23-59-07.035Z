rch depths, breaking the barrier on information density per millisecond.\\\",\\\"useLightText\\\":false}]}]}]}]\\n\"])</script><script>self.__next_f.push([1,\"6:null\\n\"])</script><script>self.__next_f.push([1,\"a:[[\\\"$\\\",\\\"title\\\",\\\"0\\\",{\\\"children\\\":\\\"Tavily\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"1\\\",{\\\"name\\\":\\\"description\\\",\\\"content\\\":\\\"Tavily is the real‑time search engine for AI agents and RAG workflows — Fast and secure APIs for web search and content extraction.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"2\\\",{\\\"name\\\":\\\"robots\\\",\\\"content\\\":\\\"index, follow\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"3\\\",{\\\"property\\\":\\\"og:title\\\",\\\"content\\\":\\\"Tavily\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"4\\\",{\\\"property\\\":\\\"og:description\\\",\\\"content\\\":\\\"Tavily is the real‑time search engine for AI agents and RAG workflows — Fast and secure APIs for web search and content extraction.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"5\\\",{\\\"property\\\":\\\"og:image\\\",\\\"content\\\":\\\"https://cdn.sanity.io/images/5tlb0lxv/production/6f74416f266192b10b3d6c220af3003846e8f17c-1200x630.png?w=1200\\u0026h=630\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"6\\\",{\\\"property\\\":\\\"og:type\\\",\\\"content\\\":\\\"website\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"7\\\",{\\\"name\\\":\\\"twitter:card\\\",\\\"content\\\":\\\"summary_large_image\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"8\\\",{\\\"name\\\":\\\"twitter:title\\\",\\\"content\\\":\\\"Tavily\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"9\\\",{\\\"name\\\":\\\"twitter:description\\\",\\\"content\\\":\\\"Tavily is the real‑time search engine for AI agents and RAG workflows — Fast and secure APIs for web search and content extraction.\\\"}],[\\\"$\\\",\\\"meta\\\",\\\"10\\\",{\\\"name\\\":\\\"twitter:image\\\",\\\"content\\\":\\\"https://cdn.sanity.io/images/5tlb0lxv/production/6f74416f266192b10b3d6c220af3003846e8f17c-1200x630.png?w=1200\\u0026h=630\\\"}],[\\\"$\\\",\\\"link\\\",\\\"11\\\",{\\\"rel\\\":\\\"shortcut