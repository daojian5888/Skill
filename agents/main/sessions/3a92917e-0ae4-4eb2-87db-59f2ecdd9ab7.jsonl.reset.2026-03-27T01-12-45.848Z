{"type":"message","id":"c653bda2","parentId":"69c490f9","timestamp":"2026-03-26T04:56:16.903Z","message":{"role":"toolResult","toolCallId":"call_function_po9c0dns3b25_2","toolName":"feishu_im_user_message","content":[{"type":"text","text":"{\n  \"message_id\": \"om_x100b537f89c560b0b22414be2a2c069\",\n  \"chat_id\": \"oc_425c881254e5b0f0981fac04f699b375\",\n  \"create_time\": \"1774500976716\"\n}"}],"details":{"message_id":"om_x100b537f89c560b0b22414be2a2c069","chat_id":"oc_425c881254e5b0f0981fac04f699b375","create_time":"1774500976716"},"isError":false,"timestamp":1774500976851}}
