ype\": \"text\"\n          }\n        ]\n      },\n      \"record_id\": \"recvdzq47prv5I\"\n    },\n    {\n      \"fields\": {\n        \"SourceID\": [\n          {\n            \"text\": \"NzU4MTUyNTA1MTIzNzgyOTU3MjpSZWNvcmRfMTc3MzIyMzIwMDAwMF83NDgwMDE1MjY5MTE3OTE5MjM0OjI1ODI5ZTVmZGZjZTc3N2Q1YmY3YzJmOTlmYTVhODA1OjE=\",\n            \"type\": \"text\"\n          }\n        ],\n        \"recordID\": [\n          {\n            \"text\": \"Record_1773223200000_7480015269117919234\",\n            \"type\": \"text\"\n          }\n        ],\n        \"今日总结：清晰罗列今日所有工作事项，明确每项工作的完成情况及达成成果。\": [\n          {\n            \"text\": \"胶州康佑一生养老院整改方案已发给客户  \\n崂山酒店电话项目和客户线上会议沟通需求 需配合电信电话中继业务 目前报价还未出\\n山东高速项目门禁 改造方案已做完 找主任汇报方案 目前要求进场施工 设备货期需要三到四天\\n见面城阳瑞麒公馆物业经理 工堪现场 监控利旧改造 刘总意思使用电信云视频方案 按云视频方案施工报价\\n\\n\",\n            \"type\": \"text\"\n          }\n        ],\n        \"图表筛选时间\": 1773244800000,\n        \"实际提交日期\": 1773242120870,\n        \"实际提交时间\": 1773242120870,\n        \"已读数\": 2,\n        \"开始时间\": 1773223200000,\n        \"当前所属部门\": \"营销部\",\n        \"抄送人\": [\n          {\n            \"avatar_url\": \"https://s3-imfile.feishucdn.com/static-resource/v1/v3_00ue_ffe1fdea-a205-4bb4-9cc0-c9ade9a0c1dg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"liuxiao@qddaojian.com\",\n            \"en_name\": \"刘晓\",\n            \"id\": \"ou_2c47b54a9dbdbd13729a411a625283a1\",\n            \"name\": \"刘晓\"\n          }\n        ],\n        \"提交人\": [\n          {\n            \"avatar_url\": \"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00uh_5235c704-f400-4553-950a-b3b11f6e7ecg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"wangyuanhao@qddaojian.com\",\n            \"en_name\": \"王垣皓\",\n            \"id\": \"ou_0a41155c9f7ed341a3c314470ad4768c\",\n            \"name\": \"王垣皓\"\n          }\n        ],\n        \"提交人.人员类型\": \"正式\",\n        \"提交人.直属上级\": [\n          {\n            \"avatar_url\": \"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00ue_d52865b3-2541-4888-a061-f37be41a601g~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"hejie@qddaojian.com\",\n            \"en_name\": \"何杰\",\n            \"id\": \"ou_35fb190135a668a941cf060191cd58e0\",\n            \"name\": \"何杰\"\n          }\n        ],\n        \"提交人.职务\": \"销售顾问\",\n        \"提交开始日期\": 1773223200000,\n        \"提交截止日期\": 1773244800000,\n        \"提交截止时间\": 1773244800000,\n        \"提交状态\": \"准时提交\",\n        \"明日计划：明确明日核心工作事项，标注每项工作的具体目标、完成时限，确保工作可落地、可跟踪。\": [\n          {\n            \"text\": \"见面于咏梅丁建亮杨天才 杨天才青钢项目目前有新进展  客工反馈项目实施比较简单 了解到孙志磊意思就想让五棵松施工 客户经理目前没拿订主意 今天晚上已到董家口 明天上午八点半找杨天才\\n下午和吴国欣工堪现场\\n\",\n            \"type\": \"text\"\n          }\n        ],\n        \"最后编辑时间\": 1773242120870,\n        \"汇报对象\": [\n          {\n            \"avatar_url\": \"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00ue_d52865b3-2541-4888-a061-f37be41a601g~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"hejie@qddaojian.com\",\n            \"en_name\": \"何杰\",\n            \"id\": \"ou_35fb190135a668a941cf060191cd58e0\",\n            \"name\": \"何杰\"\n          },\n          {\n            \"avatar_url\": \"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00sr_757d88bb-79d9-4590-bd71-07916689abfg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"yaolin@qddaojian.com\",\n            \"en_name\": \"姚霖\",\n            \"id\": \"ou_d75c71eb9cc3369175d62f2892cd7b8b\",\n            \"name\": \"姚霖\"\n          }\n        ],\n        \"汇报类型\": [\n          \"汇报或抄送给我的\"\n        ],\n        \"点赞数\": 0,\n        \"经验沉淀：提炼今日工作中的有效方法、心得感悟，或遇到问题后的解决思路，突出实用性。\": [\n          {\n            \"text\": \"供应商提供方案 需提前检查  给供应商留出整改时间\\n\",\n            \"type\": \"te