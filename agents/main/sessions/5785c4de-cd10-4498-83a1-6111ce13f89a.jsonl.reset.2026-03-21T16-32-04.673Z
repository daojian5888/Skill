\": \"hejie@qddaojian.com\",\n            \"en_name\": \"何杰\",\n            \"id\": \"ou_35fb190135a668a941cf060191cd58e0\",\n            \"name\": \"何杰\"\n          }\n        ],\n        \"汇报类型\": [\n          \"汇报或抄送给我的\"\n        ],\n        \"点赞数\": 0,\n        \"经验沉淀：提炼今日工作中的有效方法、心得感悟，或遇到问题后的解决思路，突出实用性。\": [\n          {\n            \"text\": \"\\n\",\n            \"type\": \"text\"\n          }\n        ],\n        \"评论数\": 0,\n        \"需要帮助：明确列出工作中无法自行解决，需领导或同事协调、支持的事项，便于快速对接解决。\": [\n          {\n            \"text\": \"了解政府单位 国企 其他省市国企的信创改造工作情况和难点\\n\",\n            \"type\": \"text\"\n          }\n        ]\n      },\n      \"record_id\": \"recvdzq47pa54l\"\n    },\n    {\n      \"fields\": {\n        \"SourceID\": [\n          {\n            \"text\": \"NzU4MTUyNTA1MTIzNzgyOTU3MjpSZWNvcmRfMTc3MzA1MDQwMDAwMF83NTgwMjE1MzM2NjMzMzg3OTYzOjZiNDMyOGExYzk2Nzc5OWVkYTRmYzUxYjYyMDJiZDUzOjE=\",\n            \"type\": \"text\"\n          }\n        ],\n        \"recordID\": [\n          {\n            \"text\": \"Record_1773050400000_7580215336633387963\",\n            \"type\": \"text\"\n          }\n        ],\n        \"今日总结：清晰罗列今日所有工作事项，明确每项工作的完成情况及达成成果。\": [\n          {\n            \"text\": \"1、招聘工作：在Boss直聘与应聘者沟通，共沟通27人。经过线上简历筛选，获得3份简历。\\n2、开会：深度学习公司制度，规范工作行为，严格按照公司规定操作。\\n3、编辑应收款表：根据CRM中的订单，更新应收表，已经完成。\\n\\n\",\n            \"type\": \"text\"\n          }\n        ],\n        \"图表筛选时间\": 1773072000000,\n        \"实际提交日期\": 1773051147461,\n        \"实际提交时间\": 1773051147461,\n        \"已读数\": 1,\n        \"开始时间\": 1773050400000,\n        \"当前所属部门\": \"行政部\",\n        \"提交人\": [\n          {\n            \"avatar_url\": \"https://s3-imfile.feishucdn.com/static-resource/v1/v3_00ue_ffe1fdea-a205-4bb4-9cc0-c9ade9a0c1dg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"liuxiao@qddaojian.com\",\n            \"en_name\": \"刘晓\",\n            \"id\": \"ou_2c47b54a9dbdbd13729a411a625283a1\",\n            \"name\": \"刘晓\"\n          }\n        ],\n        \"提交人.人员类型\": \"正式\",\n        \"提交人.直属上级\": [\n          {\n            \"avatar_url\": \"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00sr_757d88bb-79d9-4590-bd71-07916689abfg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"yaolin@qddaojian.com\",\n            \"en_name\": \"姚霖\",\n            \"id\": \"ou_d75c71eb9cc3369175d62f2892cd7b8b\",\n            \"name\": \"姚霖\"\n          }\n        ],\n        \"提交人.职务\": \"行政经理\",\n        \"提交开始日期\": 1773050400000,\n        \"提交截止日期\": 1773072000000,\n        \"提交截止时间\": 1773072000000,\n        \"提交状态\": \"准时提交\",\n        \"明日计划：明确明日核心工作事项，标注每项工作的具体目标、完成时限，确保工作可落地、可跟踪。\": [\n          {\n            \"text\": \"1、制作发票明细表：准确记录并完成，核对CRM的发票情况。\\n2、更新校准工资条：与姚总沟通工资条的细节后，更新工资条。\\n3、发布工资条：在飞书发布工资条，经全员同意。\\n4、统计报销单：统计员工报销单，并制作报销单表。\\n5、发布工资与报销：通过付款申请后提交至网银。\\n\",\n            \"type\": \"text\"\n          }\n        ],\n        \"最后编辑时间\": 1773051147461,\n        \"汇报对象\": [\n          {\n            \"avatar_url\": \"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00sr_757d88bb-79d9-4590-bd71-07916689abfg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"yaolin@qddaojian.com\",\n            \"en_name\": \"姚霖\",\n            \"id\": \"ou_d75c71eb9cc3369175d62f2892cd7b8b\",\n            \"name\": \"姚霖\"\n          },\n          {\n            \"avatar_url\": \"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00ue_d52865b3-2541-4888-a061-f37be41a601g~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"hejie@qddaojian.com\",\n            \"en_name\": \"何杰\",\n            \"id\": \"ou_35fb190135a668a941cf060191cd58e0\",\n            \"name\": \"何杰\"\n          }\n        ],\n        \"汇报类型\": [\n          \"汇报或抄送给我的\"\n        ],\n        \"点赞数\": 0,\n        \"经验沉淀：提炼今日工作中的有效方法、心得感悟，或遇到问题后的解决思路，突出实用性。\": [\n          {\n            \"text\": \"1、把自己设置成应聘者去看同行的岗位发布情况，可以更好的总结本公司的招聘优势。\\n2、更新招聘短语，把销售岗位做一个简短的介绍，可以更好的提高招聘效率。\\n3、利用CRM的导出功能，更准确的制作应收款表格。\\n\",\n            \"type\": \"text\"\n          }\n        ],\n        \"评论数\": 0\n      },\n      \"record_id\": \"recvdzq47pkDyw\"\n    },\n    {\n      \"fields\": {\n        \"SourceID\": [\n          {\n            \"text\": \"NzU4MTUyNTA1MTIzNzgyOTU3MjpSZWNvcmRfMTc3MzA1MDQwMDAwMF83NTgxMzE4ODkzMjY0NzAyNjU4OjA4Y2M3NDllNGMyOTlhOTEzNzFjNjcyYzk2NTk3NjdiOjE=\",\n            \"type\": \"text\"\n          }\n        ],\n        \"recordID\": [\n          {\n            \"text\": \"Record_1773050400000_7581318893264702658\",\n            \"type\": \"text\"\n          }\n        ],\n        \"今日总结：清晰罗列今日所有工作事项，明确每项工作的完成情况及达成成果。\": [\n          {\n            \"text\": \"1、莱西清单报价--完成\\n2、平度电信清单报价--完成\\n3、南村项目清单报价--完成\\n4、荣柏大厦crm修改--完成\\n5、防火墙询价--未完成\\n6、周例会--完成\\n7、大水清沟清单报价--完成\\n\",\n            \"type\": \"text\"\n          }\n        ],\n        \"图表筛选时间\": 1773072000000,\n        \"实际提交日期\": 1773051649821,\n        \"实际提交时间\": 1773051649821,\n        \"已读数\": 1,\n        \"开始时间\": 1773050400000,\n        \"当前所属部门\": \"营销部\",\n        \"抄送人\": [\n          {\n            \"avatar_url\": \"https://s3-imfile.feishucdn.com/static-resource/v1/v3_00ue_ffe1fdea-a205-4bb4-9cc0-c9ade9a0c1dg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"liuxiao@qddaojian.com\",\n            \"en_name\": \"刘晓\",\n            \"id\": \"ou_2c47b54a9dbdbd13729a411a625283a1\",\n            \"name\": \"刘晓\"\n          }\n        ],\n        \"提交人\": [\n          {\n            \"avatar_url\": \"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00ug_5d225c81-778c-49df-b2e3-86bd7849110g~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp\",\n            \"email\": \"haoyanyan@qddaojian.com\",\n            \"en_name\": \"郝彦艳\",\n       