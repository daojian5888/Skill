果。":[{"text":"1、招聘工作：在Boss直聘与应聘者沟通，共沟通21人。经过线上简历筛选，获得2份简历。【完成】\n2、更新校准工资条：与姚总沟通工资条的细节后，更新工资条。【完成】\n3、发布工资条：在飞书发布工资条，经全员同意。【完成】\n4、统计报销单：统计员工报销单，并制作报销单表。【完成】\n5、发布工资与报销：通过付款申请后提交至网银。【完成】\n6、商务工作：申请360供应商，网站填报。【完成】\n7、商务工作：处理电信表单打印盖章邮寄。【完成】\n8、商务工作：提交开票申请。【完成】\n9、商务工作：处理锐捷合同表单填写。【完成】\n10、商务工作：电信阳光采购网合同下载沟通。【完成】\n11、商务工作：电信阳光采购网账号问题沟通。【完成50%】\n12、商务工作：闲鱼采购砍价。【完成】\n","type":"text"}],"图表筛选时间":1773158400000,"实际提交日期":1773139602522,"实际提交时间":1773139602522,"已读数":1,"开始时间":1773136800000,"当前所属部门":"行政部","提交人":[{"avatar_url":"https://s3-imfile.feishucdn.com/static-resource/v1/v3_00ue_ffe1fdea-a205-4bb4-9cc0-c9ade9a0c1dg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp","email":"liuxiao@qddaojian.com","en_name":"刘晓","id":"ou_2c47b54a9dbdbd13729a411a625283a1","name":"刘晓"}],"提交人.人员类型":"正式","提交人.直属上级":[{"avatar_url":"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00sr_757d88bb-79d9-4590-bd71-07916689abfg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp","email":"yaolin@qddaojian.com","en_name":"姚霖","id":"ou_d75c71eb9cc3369175d62f2892cd7b8b","name":"姚霖"}],"提交人.职务":"行政经理","提交开始日期":1773136800000,"提交截止日期":1773158400000,"提交截止时间":1773158400000,"提交状态":"准时提交","明日计划：明确明日核心工作事项，标注每项工作的具体目标、完成时限，确保工作可落地、可跟踪。":[{"text":"1、招聘工作：在Boss直聘与应聘者沟通，经过线上简历筛选。\n2、商务工作：跟进360供应商。\n3、商务工作：处理电信表单邮寄。\n4、商务工作：提交开票申请。\n5、商务工作：处理锐捷合同表单打印盖章。\n6、商务工作：电信阳光采购网账号问题沟通。\n7、商务工作：闲鱼采购下单。\n8、商务工作：跟进高企火炬年报事宜。\n9、商务工作：制作发票表格。\n","type":"text"}],"最后编辑时间":1773139602522,"汇报对象":[{"avatar_url":"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00sr_757d88bb-79d9-4590-bd71-07916689abfg~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp","email":"yaolin@qddaojian.com","en_name":"姚霖","id":"ou_d75c71eb9cc3369175d62f2892cd7b8b","name":"姚霖"},{"avatar_url":"https://s1-imfile.feishucdn.com/static-resource/v1/v3_00ue_d52865b3-2541-4888-a061-f37be41a601g~?image_size=72x72&cut_type=default-face&quality=&format=jpeg&sticker_format=.webp