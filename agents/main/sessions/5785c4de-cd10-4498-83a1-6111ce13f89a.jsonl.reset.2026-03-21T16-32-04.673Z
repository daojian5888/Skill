ges":[{"message_id":"om_x100b54fd3d58d0a4c34030d0b4a99e8","msg_type":"text","content":"https://qddaojian.feishu.cn/docx/Vd4NdcwAzopWxNxbUo5chq19nRe?from=vc_group_doc_link#doxcnNDLqFW46ZhJUCWnrASOzCg","sender":{"id":"cli_a6ba21656ff1d00e","sender_type":"app"},"create_time":"2026-03-20T08:39:21+08:00","deleted":false,"updated":false},{"message_id":"om_x100b54fd22d12d30b4cd669f2bb8238","msg_type":"system","content":"","sender":{"id":"","sender_type":""},"create_time":"2026-03-20T08:37:21+08:00","deleted":false,"updated":false},{"message_id":"om_x100b54fd77ca5428b36e302969d57a4","msg_type":"video_chat","content":"<meeting>📹 销售晨会\n🕙 2026-03-20 08:29</meeting>","sender":{"id":"ou_35fb190135a668a941cf060191cd58e0","sender_type":"user","name":"何杰"},"create_time":"2026-03-20T08:29:35+08:00","deleted":false,"updated":true},{"message_id":"om_x100b54fd003b88acc3acc4cbc283d20","msg_type":"system","content":"Meeting has started. New messages will be synced in the group chat and in-meeting chat.","sender":{"id":"","sender_type":""},"create_time":"2026-03-20T08:29:35+08:00","deleted":false,"updated":false}],"has_more":false,"page_token":""},"isError":false,"timestamp":1774107985759}}
