{"type":"message","id":"0da5d871","parentId":"a3202236","timestamp":"2026-03-12T16:37:32.778Z","message":{"role":"toolResult","toolCallId":"call_function_hxymgekcqrwi_1","toolName":"exec","content":[{"type":"text","text":"NAME:\n   miaoda-studio-cli search-summary - Search web and generate AI summary\n\nUSAGE:\n   miaoda-studio-cli search-summary [command options] [arguments...]\n\nOPTIONS:\n   --query value             Search query (1-500 chars)\n   --instruction value       Processing instruction for AI\n   --output value, -o value  Output format: text (default) or json (default: \"text\")\n   --help, -h                show help\nError: Required flag \"query\" not set"}],"details":{"status":"completed","exitCode":0,"durationMs":9,"aggregated":"NAME:\n   miaoda-studio-cli search-summary - Search web and generate AI summary\n\nUSAGE:\n   miaoda-studio-cli search-summary [command options] [arguments...]\n\nOPTIONS:\n   --query value             Search query (1-500 chars)\n   --instruction value       Processing instruction for AI\n   --output value, -o value  Output format: text (default) or json (default: \"text\")\n   --help, -h                show help\nError: Required flag \"query\" not set","cwd":"/home/gem/workspace/agent/workspace"},"isError":false,"timestamp":1773333452769}}
