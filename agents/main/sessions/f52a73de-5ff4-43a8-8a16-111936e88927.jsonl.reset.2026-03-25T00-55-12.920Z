-24T03:25:22+08:00","url":"https://qddaojian.feishu.cn/wiki/YLqfw9zkfiP6I7kgYz9cWOmVnVe#doxcnMUYuCZTzLxhgeQ5c07VcIh"},"summary_highlighted":"<b>2.2 </b><hb>培训</hb><b>管理制度</b>   <b>第一章 总则</b>   <b>一、制度目的</b>","title_highlighted":"<h>培训子系统</h>（2.2-<h>DJ</h>MS-PX）"},{"entity_type":"WIKI","result_meta":{"create_time":"2025-12-24T15:56:27+08:00","doc_types":"DOCX","edit_user_id":"ou_d75c71eb9cc3369175d62f2892cd7b8b","edit_user_name":"姚霖","last_open_time":"2026-03-09T11:45:51+08:00","owner_id":"ou_d75c71eb9cc3369175d62f2892cd7b8b","owner_name":"姚霖","token":"UQpKwQJTRiOX5rksqtdceAllndq","update_time":"2026-03-24T03:26:37+08:00","url":"https://qddaojian.feishu.cn/wiki/UQpKwQJTRiOX5rksqtdceAllndq#doxcnprTlnyZgbLh6hM79dkD0Zc"},"summary_highlighted":"<b>2.3 </b><hb>培训</hb><b>应用系统操作指南</b>   <b>第一章 系统概述</b>   <b>一、系统定位</b>","title_highlighted":"<h>培训子系统</h>（2.3-<h>DJ</h>AS-PX）"},{"entity_type":"WIKI","result_meta":{"create_time":"2026-03-24T00:15:42+08:00","doc_types":"DOCX","edit_user_id":"ou_d75c71eb9cc3369175d62f2892cd7b8b","edit_user_name":"姚霖","last_open_time":"2026-03-24T08:58:22+08:00","owner_id":"ou_d75c71eb9cc3369175d62f2892cd7b8b","owner_name":"姚霖","token":"Ld7cws0IZipqubkyXc0cffZEn8d","update_time":"2026-03-24T00:15:43+08:00","url":"https://qddaojian.feishu.cn/wiki/Ld7cws0IZipqubkyXc0cffZEn8d"},"summary_highlighted":"操作<h>系统</h>（<h>DJOS</h>）   <h>培训子系统</h>","title_highlighted":"道简网络操作<h>系统培训</h>学习笔记"}],"page_token":"{\"Mode\":0,\"GeoStrategyInfos\":{\"eu_nc\":{\"Mode\":0,\"Size\":20,\"Offset\":6,\"PreviousOffset\":0,\"Total\":6,\"strategies_infos\":[{\"strategies\":{},\"before_current_strategy_have_recalled_count\":0},{\"strategies\":{},\"before_current_strategy_have_recalled_count\":6}],\"last_strategy_infos\":{\"strategies\":{},\"before_current_strategy_have_recalled_count\":0},\"search_cold\":true}},\"size\":20,\"offset\":6,\"total\":6,\"shown_recordids_cache_Key\":\"7133889645745618945_45f8ee77-71a6-4866-88a1-7c91a9d920a2_1774332432434073133\",\"search_cold\":true