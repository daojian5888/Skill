预计2026年超70%轻量级集成场景由业务端自主实现\n\n---\n\n"}}],"api":"anthropic-messages","provider":"minimax","model":"MiniMax-M2.7","usage":{"input":5788,"output":672,"cacheRead":43981,"cacheWrite":0,"totalTokens":50441,"cost":{"input":0.0017364,"output":0.0008064,"cacheRead":0.00131943,"cacheWrite":0,"total":0.00386223}},"stopReason":"toolUse","timestamp":1774679104527}}
